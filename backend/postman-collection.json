{
  "info": {
    "name": "KampusKart API",
    "_postman_id": "kampuskart-api-collection",
    "description": "Complete API collection for KampusKart - Campus Lost & Found Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            },
            "description": "Check if the API server is running and healthy."
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"student\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "description": "Register a new user account."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Login and receive JWT token."
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Get current authenticated user profile."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Updated\",\n  \"avatar\": \"https://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/profile",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "profile"]
            },
            "description": "Update user profile information."
          }
        }
      ]
    },
    {
      "name": "Lost & Found",
      "item": [
        {
          "name": "Get All Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found?limit=20&page=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found"],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "category",
                  "value": "Electronics",
                  "disabled": true
                },
                {
                  "key": "status",
                  "value": "open",
                  "disabled": true
                },
                {
                  "key": "type",
                  "value": "lost",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "phone",
                  "disabled": true
                }
              ]
            },
            "description": "Get all items with optional filters and pagination."
          }
        },
        {
          "name": "Get Item by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "6789abcd1234567890abcdef"
                }
              ]
            },
            "description": "Get a specific item by ID."
          }
        },
        {
          "name": "Create Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lost iPhone 13\",\n  \"description\": \"Black iPhone 13 with blue case. Lost near library.\",\n  \"category\": \"Electronics\",\n  \"type\": \"lost\",\n  \"location\": \"Main Library, 2nd Floor\",\n  \"lastSeenDate\": \"2026-01-17T14:30:00Z\",\n  \"contactInfo\": \"john@example.com\",\n  \"imageURL\": \"https://res.cloudinary.com/example/image.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/lost-found",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found"]
            },
            "description": "Create a new lost or found item."
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"resolved\",\n  \"description\": \"Updated description - item has been found!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "6789abcd1234567890abcdef"
                }
              ]
            },
            "description": "Update an existing item (owner only)."
          }
        },
        {
          "name": "Delete Item",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "6789abcd1234567890abcdef"
                }
              ]
            },
            "description": "Delete an item (owner only, soft delete)."
          }
        },
        {
          "name": "Get Recent Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/recent?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", "recent"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            },
            "description": "Get most recently created items."
          }
        },
        {
          "name": "Get Statistics",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/statistics",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", "statistics"]
            },
            "description": "Get overall statistics for items."
          }
        },
        {
          "name": "Get Items by Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/category/:category?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", "category", ":category"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ],
              "variable": [
                {
                  "key": "category",
                  "value": "Electronics"
                }
              ]
            },
            "description": "Get items filtered by category."
          }
        },
        {
          "name": "Get Items by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/lost-found/status/:status?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "lost-found", "status", ":status"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ],
              "variable": [
                {
                  "key": "status",
                  "value": "open"
                }
              ]
            },
            "description": "Get items filtered by status."
          }
        }
      ]
    },
    {
      "name": "Upload",
      "item": [
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "upload"]
            },
            "description": "Upload an image to Cloudinary."
          }
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/upload/:publicId",
              "host": ["{{baseUrl}}"],
              "path": ["api", "upload", ":publicId"],
              "variable": [
                {
                  "key": "publicId",
                  "value": "kampuskart%2Fimage123"
                }
              ]
            },
            "description": "Delete an image from Cloudinary."
          }
        }
      ]
    }
  ]
}
